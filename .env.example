# --- Postgres ---
POSTGRES_USER=<admin_username>
POSTGRES_PASSWORD=<change_me_in_real_env>
POSTGRES_DB=<db_name>
POSTGRES_PORT=55475
POSTGRES_DATA=./pgsql
POSTGRES_HOST=postgres
POSTGRES_POOL_SIZE=8

# --- API ---
# JWT signing key. In production this should be 32+ random bytes.  Can use https://jwtsecretkeygenerator.com/ to generate a secure key.
JWT_SECRET=<replace_with_a_long_random_string_at_least_32_chars>
JWT_ISSUER=ProductCatalogApi
JWT_AUDIENCE=ProductCatalogClient
JWT_EXPIRY_MINUTES=60